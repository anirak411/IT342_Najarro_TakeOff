<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_dialog"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvInboxTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/inbox_title"
            android:textColor="@color/text_main"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnInboxClose"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:background="@drawable/bg_btn_outline"
            android:minHeight="0dp"
            android:text="@string/action_close"
            android:textAllCaps="false"
            android:textColor="@color/text_main"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvInboxSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/inbox_subtitle"
        android:textColor="@color/text_sub"
        android:textSize="12sp" />

    <ProgressBar
        android:id="@+id/progressInbox"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvInboxEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_glass_panel"
        android:padding="12dp"
        android:text="@string/inbox_empty"
        android:textColor="@color/text_sub"
        android:textSize="13sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvInboxThreads"
        android:layout_width="match_parent"
        android:layout_height="360dp"
        android:layout_marginTop="10dp"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

</LinearLayout>
